<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - RSVP Dashboard</title>
  <link rel="stylesheet" href="/css/styles.css" />
  
</head>
<body>
  <main class="page-shell">
    <section class="invite-card" style="grid-template-columns:1fr;">
      <div class="content-wrap">
        <div class="admin-topbar">
          <div>
            <p class="eyebrow">Admin</p>
            <h1>RSVP Dashboard</h1>
            <p class="small-text">Manage guests, notes, and RSVP responses.</p>
          </div>

          <div class="admin-actions">
            <a
              class="admin-link-button"
              href="/admin/export?key=<%= key %>"
            >
              Export Excel
            </a>
          </div>
        </div>

        <div class="admin-section">
          <div class="admin-card">
            <h2>Add Guest</h2>

            <form action="/admin/add-guest" method="POST">
              <input type="hidden" name="key" value="<%= key %>" />

              <div class="admin-form-grid">
                <div>
                  <label>Guest name - our version</label>
                  <input
                    type="text"
                    name="guest_name_host"
                    placeholder="Enter guest name"
                    required
                  />
                </div>

                <div>
                  <label>Phone number</label>
                  <input
                    type="text"
                    name="phone"
                    placeholder="Enter phone number"
                    required
                  />
                </div>

                <div style="grid-column: 1 / -1;">
                  <label>Notes</label>
                  <textarea
                    name="notes"
                    placeholder="Example: Close friend"
                  ></textarea>
                </div>
              </div>

              <div class="admin-inline-actions">
                <button type="submit" class="light-button">Add Guest</button>
              </div>
            </form>
          </div>
        </div>

        <div class="admin-section">
          <div class="admin-card">
            <h2>Guest List and RSVP Data</h2>

            <div class="admin-table-wrap">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Guest Name - Our Version</th>
                    <th>Guest Name - Their Version</th>
                    <th>Phone</th>
                    <th>RSVP</th>
                    <th>Message</th>
                    <th>Notes</th>
                    <th>Created</th>
                    <th>Updated</th>
                    <th>Changed?</th>
                    <th>Edit</th>
                    <th>Delete</th>
                  </tr>
                </thead>
                <tbody>
                  <% rows.forEach((row) => { %>
                    <tr>
                      <td><%= row.guest_name_host %></td>
                      <td><%= row.guest_name_user || '-' %></td>
                      <td><%= row.phone %></td>
                      <td>
                        <% if (row.attendance_status === 'Yes') { %>
                          <span class="status yes">Yes</span>
                        <% } else if (row.attendance_status === 'Maybe') { %>
                          <span class="status maybe">Maybe</span>
                        <% } else if (row.attendance_status === 'No') { %>
                          <span class="status no">No</span>
                        <% } else { %>
                          <span class="status none">No Response</span>
                        <% } %>
                      </td>
                      <td><%= row.message || '-' %></td>
                      <td><%= row.notes || '-' %></td>
                      <td><%= row.created_at || '-' %></td>
                      <td><%= row.updated_at || '-' %></td>
                      <td>
                        <% if (row.is_update) { %>
                          <span class="tag">Updated</span>
                        <% } else { %>
                          <span class="tag" style="background:#f3f4f6;color:#374151;">New / None</span>
                        <% } %>
                      </td>
                      <td>
                        <form action="/admin/update-guest" method="POST">
                          <input type="hidden" name="key" value="<%= key %>" />

                          <input type="hidden" name="original_phone" value="<%= row.phone %>" />

                          <div class="admin-form-grid">
                            <input
                              type="text"
                              name="guest_name_host"
                              value="<%= row.guest_name_host %>"
                              required
                            />

                            <input
                              type="text"
                              name="phone"
                              value="<%= row.phone %>"
                              required
                            />

                            <select 
                              name="attendance_status" 
                              class="rsvp-select <%= 
                                row.attendance_status === 'Yes' ? 'rsvp-yes' :
                                row.attendance_status === 'Maybe' ? 'rsvp-maybe' :
                                row.attendance_status === 'No' ? 'rsvp-no' :
                                'rsvp-none'
                              %>"
                            >
                              <option value="">No Response</option>
                              <option value="Yes" <%= row.attendance_status === 'Yes' ? 'selected' : '' %>>Yes</option>
                              <option value="Maybe" <%= row.attendance_status === 'Maybe' ? 'selected' : '' %>>Maybe</option>
                              <option value="No" <%= row.attendance_status === 'No' ? 'selected' : '' %>>No</option>                            
                            </select>

                            <textarea
                              name="notes"
                              placeholder="Notes"
                            ><%= row.notes || '' %></textarea>
                          </div>

                          <div class="admin-inline-actions">
                            <button type="submit" class="secondary-button">Save</button>
                          </div>
                        </form>
                      </td>
                      <td>
                        <form action="/admin/delete-guest" method="POST" onsubmit="return confirm('Delete this guest and any RSVP data?');">
                          <input type="hidden" name="key" value="<%= key %>" />

                          <input type="hidden" name="phone" value="<%= row.phone %>" />
                          <button type="submit" class="danger-button">Delete</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</body>
</html>