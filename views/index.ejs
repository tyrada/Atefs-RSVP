<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RSVP Invitation</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
  </head>
  <body>
    <main class="page-shell">
      <section class="invite-card">
        <div class="thumbnail-wrap">
          <img
            src="/images/invite.jpg"
            alt="Invitation thumbnail"
            class="invite-thumbnail"
          />
        </div>

        <div class="content-wrap">
          <p class="eyebrow">RSVP</p>
          <h1>Men only - invitation</h1>
          <p class="guest-limit">for 1 person only</p>
          <p class="deadline">RSVP by Apr 22, 2026</p>

          <% if (success) { %>
            <div class="alert success"><%= success %></div>
          <% } %>

          <% if (error) { %>
            <div class="alert error"><%= error %></div>
          <% } %>

          <form action="/rsvp" method="POST" class="rsvp-form">
            <div class="form-group">
              <label>Will you attend?</label>
              <div class="choice-group">
                <label class="choice-pill yes-pill">
                  <input type="radio" name="attendance" value="Yes" required />
                  <span>Yes</span>
                </label>
                <label class="choice-pill maybe-pill">
                  <input type="radio" name="attendance" value="Maybe" />
                  <span>Maybe</span>
                </label>
                <label class="choice-pill no-pill">
                  <input type="radio" name="attendance" value="No" />
                  <span>No</span>
                </label>
              </div>
            </div>

            <div class="form-group">
              <label for="name">Name *</label>
              <input id="name" name="name" type="text" placeholder="Your name" required />
            </div>

            <div class="form-group">
              <label for="contact">Phone Number *</label>
              <input
                id="contact"
                name="contact"
                type="tel"
                placeholder="Your phone number"
                required
              />
            </div>

            <div class="form-group">
              <label for="message">Leave a message for the host</label>
              <textarea
                id="message"
                name="message"
                placeholder="Your message"
                maxlength="250"
                rows="4"
              ></textarea>
            </div>

            <div class="limit-note">Guest limit enforced: 1 RSVP per phone number.</div>

            <button type="submit" class="submit-button">Submit</button>
          </form>
        </div>
      </section>
    </main>
  </body>
</html>
