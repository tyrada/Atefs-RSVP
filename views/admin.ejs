<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - RSVP Dashboard</title>
  <link rel="stylesheet" href="/css/styles.css" />
  <style>
    .admin-topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }

    .admin-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .admin-link-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 18px;
      border-radius: 999px;
      background: #22c55e;
      color: #ffffff;
      font-weight: 700;
      text-decoration: none;
    }

    .admin-section {
      margin-top: 28px;
    }

    .admin-card {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 20px;
      padding: 20px;
      margin-bottom: 20px;
    }

    .admin-form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 14px;
      margin-top: 14px;
    }

    .admin-form-grid input,
    .admin-form-grid textarea {
      width: 100%;
      border: 1px solid #d0d5dd;
      border-radius: 14px;
      padding: 12px 14px;
      font: inherit;
    }

    .admin-form-grid textarea {
      min-height: 80px;
      resize: vertical;
    }

    .admin-inline-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 14px;
    }

    .admin-table-wrap {
      overflow-x: auto;
      margin-top: 20px;
    }

    .admin-table {
      width: 100%;
      border-collapse: collapse;
      min-width: 1100px;
    }

    .admin-table th,
    .admin-table td {
      padding: 12px;
      border-bottom: 1px solid #e5e7eb;
      text-align: left;
      vertical-align: top;
    }

    .admin-table th {
      font-size: 0.92rem;
      color: #475467;
    }

    .status {
      font-weight: 600;
      padding: 6px 12px;
      border-radius: 999px;
      display: inline-block;
    }

    .yes { background: #dcfce7; color: #166534; }
    .maybe { background: #fef3c7; color: #92400e; }
    .no { background: #fee2e2; color: #991b1b; }
    .none { background: #f3f4f6; color: #374151; }

    .tag {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      background: #eef2ff;
      color: #3730a3;
      font-weight: 600;
      font-size: 0.88rem;
    }

    .danger-button {
      background: #ef4444;
      color: #ffffff;
      border: none;
      border-radius: 999px;
      padding: 10px 16px;
      font-weight: 700;
      cursor: pointer;
    }

    .secondary-button {
      background: #101828;
      color: #ffffff;
      border: none;
      border-radius: 999px;
      padding: 10px 16px;
      font-weight: 700;
      cursor: pointer;
    }

    .light-button {
      background: #22c55e;
      color: #ffffff;
      border: none;
      border-radius: 999px;
      padding: 10px 16px;
      font-weight: 700;
      cursor: pointer;
    }

    .small-text {
      color: #667085;
      font-size: 0.9rem;
    }
  </style>
</head>
<body>
  <main class="page-shell">
    <section class="invite-card" style="grid-template-columns:1fr;">
      <div class="content-wrap">
        <div class="admin-topbar">
          <div>
            <p class="eyebrow">Admin</p>
            <h1>RSVP Dashboard</h1>
            <p class="small-text">Manage guests, notes, and RSVP responses.</p>
          </div>

          <div class="admin-actions">
            <a
              class="admin-link-button"
              href="/admin/export?key=<%= key %>"
            >
              Export Excel
            </a>
          </div>
        </div>

        <div class="admin-section">
          <div class="admin-card">
            <h2>Add Guest</h2>

            <form action="/admin/add-guest" method="POST">
              <input type="hidden" name="key" value="<%= key %>" />

              <div class="admin-form-grid">
                <div>
                  <label>Guest name - our version</label>
                  <input
                    type="text"
                    name="guest_name_host"
                    placeholder="Enter guest name"
                    required
                  />
                </div>

                <div>
                  <label>Phone number</label>
                  <input
                    type="text"
                    name="phone"
                    placeholder="Enter phone number"
                    required
                  />
                </div>

                <div style="grid-column: 1 / -1;">
                  <label>Notes</label>
                  <textarea
                    name="notes"
                    placeholder="Example: Close friend"
                  ></textarea>
                </div>
              </div>

              <div class="admin-inline-actions">
                <button type="submit" class="light-button">Add Guest</button>
              </div>
            </form>
          </div>
        </div>

        <div class="admin-section">
          <div class="admin-card">
            <h2>Guest List and RSVP Data</h2>

            <div class="admin-table-wrap">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Guest Name - Our Version</th>
                    <th>Guest Name - Their Version</th>
                    <th>Phone</th>
                    <th>RSVP</th>
                    <th>Message</th>
                    <th>Notes</th>
                    <th>Created</th>
                    <th>Updated</th>
                    <th>Changed?</th>
                    <th>Edit</th>
                    <th>Delete</th>
                  </tr>
                </thead>
                <tbody>
                  <% rows.forEach((row) => { %>
                    <tr>
                      <td><%= row.guest_name_host %></td>
                      <td><%= row.guest_name_user || '-' %></td>
                      <td><%= row.phone %></td>
                      <td>
                        <% if (row.attendance_status === 'Yes') { %>
                          <span class="status yes">Yes</span>
                        <% } else if (row.attendance_status === 'Maybe') { %>
                          <span class="status maybe">Maybe</span>
                        <% } else if (row.attendance_status === 'No') { %>
                          <span class="status no">No</span>
                        <% } else { %>
                          <span class="status none">No Response</span>
                        <% } %>
                      </td>
                      <td><%= row.message || '-' %></td>
                      <td><%= row.notes || '-' %></td>
                      <td><%= row.created_at || '-' %></td>
                      <td><%= row.updated_at || '-' %></td>
                      <td>
                        <% if (row.is_update) { %>
                          <span class="tag">Updated</span>
                        <% } else { %>
                          <span class="tag" style="background:#f3f4f6;color:#374151;">New / None</span>
                        <% } %>
                      </td>
                      <td>
                        <form action="/admin/update-guest" method="POST">
                          <input type="hidden" name="key" value="<%= key %>" />

                          <input type="hidden" name="original_phone" value="<%= row.phone %>" />

                          <div class="admin-form-grid">
                            <input
                              type="text"
                              name="guest_name_host"
                              value="<%= row.guest_name_host %>"
                              required
                            />

                            <input
                              type="text"
                              name="phone"
                              value="<%= row.phone %>"
                              required
                            />

                            <select 
                              name="attendance_status" 
                              class="rsvp-select <%= 
                                row.attendance_status === 'Yes' ? 'rsvp-yes' :
                                row.attendance_status === 'Maybe' ? 'rsvp-maybe' :
                                row.attendance_status === 'No' ? 'rsvp-no' :
                                'rsvp-none'
                              %>"
                            >
                              <option value="">No Response</option>
                              <option value="Yes" <%= row.attendance_status === 'Yes' ? 'selected' : '' %>>Yes</option>
                              <option value="Maybe" <%= row.attendance_status === 'Maybe' ? 'selected' : '' %>>Maybe</option>
                              <option value="No" <%= row.attendance_status === 'No' ? 'selected' : '' %>>No</option>                            
                            </select>

                            <textarea
                              name="notes"
                              placeholder="Notes"
                            ><%= row.notes || '' %></textarea>
                          </div>

                          <div class="admin-inline-actions">
                            <button type="submit" class="secondary-button">Save</button>
                          </div>
                        </form>
                      </td>
                      <td>
                        <form action="/admin/delete-guest" method="POST" onsubmit="return confirm('Delete this guest and any RSVP data?');">
                          <input type="hidden" name="key" value="<%= key %>" />

                          <input type="hidden" name="phone" value="<%= row.phone %>" />
                          <button type="submit" class="danger-button">Delete</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</body>
</html>